{{ define "content" }}
<div style="margin:24px 0;">
  <div class="fade-in" style="margin-bottom:24px;">
    <div class="section-title">
      <h1 style="font-size:24px;color:var(--color-gray-800);">所有板块</h1>
      <span style="font-size:13px;color:var(--color-gray-500);">共 {{ len .Categories }} 个板块</span>
    </div>
  </div>

  <div class="category-grid fade-in fade-in-delay-1" style="grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px;">
    {{ range $i, $c := .Categories }}
    <a href="/c/{{ $c.Slug }}" class="glass-card glass-card-hover" style="padding:24px;display:block;text-decoration:none;color:inherit;animation:fadeInUp .5s ease-out both;animation-delay:{{ mulf $i 0.05 }}s;">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;">
        <div style="width:52px;height:52px;border-radius:var(--radius-lg);background:linear-gradient(135deg,var(--color-primary),var(--color-primary-2));display:flex;align-items:center;justify-content:center;color:white;flex-shrink:0;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
        </div>
        <div>
          <h3 style="font-size:16px;color:var(--color-gray-800);margin-bottom:2px;">{{ $c.Name }}</h3>
          <span class="tag" style="font-size:11px;">{{ $c.TopicCount }} 主题</span>
        </div>
      </div>
      <p style="font-size:13px;color:var(--color-gray-500);line-height:1.6;margin-bottom:14px;min-height:40px;">
        {{ if $c.Description }}{{ $c.Description }}{{ else }}暂无描述{{ end }}
      </p>
      <div style="display:flex;gap:16px;font-size:12px;color:var(--color-gray-400);">
        <span><strong style="color:var(--color-gray-600);">{{ $c.TopicCount }}</strong> 帖子</span>
      </div>
    </a>
    {{ end }}
  </div>

  <div style="margin-top:40px;" class="fade-in fade-in-delay-2">
    <div class="section-title">
      <h2>热门帖子</h2>
      <a href="/" style="font-size:13px;">查看更多 →</a>
    </div>
    <div class="topic-list">
      {{ range $i, $t := .HotTopics }}
      <div class="topic-item" style="animation:fadeInUp .5s ease-out both;animation-delay:{{ addf $i 0.3 }}s;">
        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ $t.Author.Username }}" alt="" class="topic-avatar">
        <div class="topic-main">
          <div class="topic-title">
            {{ if $t.IsEssence }}<span class="tag tag-essence">精华</span>{{ end }}
            <a href="/t/{{ $t.ID }}">{{ $t.Title }}</a>
          </div>
          <div class="topic-meta">
            <span class="author">{{ $t.Author.Username }}</span>
            <span>{{ $t.Category.Name }}</span>
            <span>{{ relativeTime $t.CreatedAt }}</span>
          </div>
        </div>
        <div class="topic-stats">
          <span title="回复">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {{ $t.ReplyCount }}
          </span>
        </div>
      </div>
      {{ end }}
    </div>
  </div>
</div>
{{ end }}
