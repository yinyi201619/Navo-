{{ define "content" }}
<div class="layout-grid">
  <div class="layout-main">
    <div class="glass-card topic-detail fade-in">
      <div class="topic-detail-header">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
          <a href="/c/{{ .Topic.Category.Slug }}" class="tag">{{ .Topic.Category.Name }}</a>
          {{ if .Topic.IsPinned }}<span class="tag tag-pin">置顶</span>{{ end }}
          {{ if .Topic.IsEssence }}<span class="tag tag-essence">精华</span>{{ end }}
          {{ range .Topic.Tags }}
          <span class="tag" style="background:rgba(139,92,246,0.1);color:var(--color-primary-2);">{{ . }}</span>
          {{ end }}
        </div>
        <h1>{{ .Topic.Title }}</h1>
        <div class="topic-detail-meta">
          <div class="topic-author">
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ .Topic.Author.Username }}" alt="">
            <div class="topic-author-info">
              <strong>
                <a href="/u/{{ .Topic.Author.Username }}" style="color:inherit;">{{ .Topic.Author.Username }}</a>
                {{ if .Topic.Author.IsVerified }}
                <span class="verified-badge">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  认证
                </span>
                {{ end }}
              </strong>
              <span>Lv.{{ .Topic.Author.Level }} · {{ relativeTime .Topic.CreatedAt }} · {{ .Topic.ViewCount }} 浏览</span>
            </div>
          </div>
        </div>
      </div>

      <div class="topic-content">
        {{ .Topic.ContentHTML }}
      </div>

      <div class="topic-actions">
        <button class="action-btn {{ if .IsLiked }}active{{ end }}" onclick="toggleLike({{ .Topic.ID }})">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span id="like-count">{{ .Topic.LikeCount }}</span> 点赞
        </button>
        <button class="action-btn {{ if .IsFavorited }}active{{ end }}" onclick="toggleFavorite({{ .Topic.ID }})">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span id="favorite-count">{{ .Topic.FavoriteCount }}</span> 收藏
        </button>
        <button class="action-btn" onclick="shareTopic()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          分享
        </button>
        {{ if .IsLogin }}
        <button class="action-btn" onclick="scrollToReply()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          回复
        </button>
        {{ end }}
      </div>
    </div>

    <div class="reply-section fade-in fade-in-delay-1">
      <h2>全部回复 ({{ .TotalReplies }})</h2>

      {{ range $i, $r := .Replies }}
      <div class="reply-item" id="reply-{{ $r.ID }}">
        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ $r.Author.Username }}" alt="" class="reply-avatar">
        <div class="reply-main">
          <div class="reply-header">
            <div class="reply-author">
              <a href="/u/{{ $r.Author.Username }}" style="color:inherit;">{{ $r.Author.Username }}</a>
              <span class="level-badge">Lv.{{ $r.Author.Level }}</span>
            </div>
            <span class="reply-floor">#{{ add $i 1 }}楼 · {{ relativeTime $r.CreatedAt }}</span>
          </div>
          <div class="reply-content">
            {{ $r.ContentHTML }}
          </div>
          <div class="reply-actions">
            <a href="#" onclick="likeReply({{ $r.ID }});return false;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {{ $r.LikeCount }}
            </a>
            <a href="#" onclick="replyTo({{ $r.ID }}, '{{ $r.Author.Username }}');return false;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17l-5-5 5-5M20 18v-2a4 4 0 0 0-4-4H4"/></svg>
              回复
            </a>
            {{ if $.IsAdmin }}
            <a href="#" onclick="deleteReply({{ $r.ID }});return false;" style="color:var(--color-danger);">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              删除
            </a>
            {{ end }}
          </div>
        </div>
      </div>
      {{ else }}
      <div class="glass-card" style="padding:40px;text-align:center;color:var(--color-gray-500);">
        暂无回复，快来抢沙发吧~
      </div>
      {{ end }}

      {{ if .TotalPages }}
      <div class="pagination">
        {{ if eq .Page 1 }}
        <span class="disabled">上一页</span>
        {{ else }}
        <a href="?page={{ sub .Page 1 }}">上一页</a>
        {{ end }}
        {{ range $i := seq 1 .TotalPages }}
          {{ if eq $i $.Page }}
          <span class="current">{{ $i }}</span>
          {{ else }}
          <a href="?page={{ $i }}">{{ $i }}</a>
          {{ end }}
        {{ end }}
        {{ if eq .Page .TotalPages }}
        <span class="disabled">下一页</span>
        {{ else }}
        <a href="?page={{ add .Page 1 }}">下一页</a>
        {{ end }}
      </div>
      {{ end }}

      {{ if .IsLogin }}
      <div class="reply-form" id="reply-form">
        <h3 style="font-size:16px;margin-bottom:14px;color:var(--color-gray-800);">发表回复</h3>
        <form method="post" action="/t/{{ .Topic.ID }}/reply">
          <input type="hidden" name="reply_to" id="reply-to-id" value="0">
          <div id="reply-to-notice" style="display:none;padding:8px 12px;background:rgba(99,102,241,0.08);border-radius:var(--radius-md);margin-bottom:12px;font-size:13px;color:var(--color-primary);">
            正在回复 <span id="reply-to-name"></span> <a href="#" onclick="cancelReply();return false;" style="float:right;">取消</a>
          </div>
          <textarea name="content" class="form-textarea" rows="4" placeholder="写下你的回复..." required></textarea>
          <div style="margin-top:12px;text-align:right;">
            <button type="submit" class="btn btn-primary">发 表 回 复</button>
          </div>
        </form>
      </div>
      {{ else }}
      <div class="reply-form" style="text-align:center;">
        <p style="color:var(--color-gray-500);margin-bottom:12px;">登录后即可发表回复</p>
        <a href="/login" class="btn btn-primary">登录</a>
        <a href="/register" class="btn btn-secondary" style="margin-left:8px;">注册</a>
      </div>
      {{ end }}
    </div>
  </div>

  <div class="layout-side">
    <div class="glass-card user-card fade-in">
      <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ .Topic.Author.Username }}" alt="" class="user-card-avatar">
      <div class="user-card-name">
        {{ .Topic.Author.Username }}
        {{ if .Topic.Author.IsVerified }}
        <span class="verified-badge">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </span>
        {{ end }}
      </div>
      <div class="user-card-sign">{{ if .Topic.Author.Signature }}{{ .Topic.Author.Signature }}{{ else }}这个人很懒，什么都没写{{ end }}</div>
      <div class="user-card-stats">
        <div>
          <strong>{{ .Topic.Author.Level }}</strong>
          <span>等级</span>
        </div>
        <div>
          <strong>{{ .Topic.Author.TopicCount }}</strong>
          <span>帖子</span>
        </div>
        <div>
          <strong>{{ .Topic.Author.ReplyCount }}</strong>
          <span>回复</span>
        </div>
      </div>
      {{ if .IsLogin }}
      <div style="margin-top:14px;display:flex;gap:8px;">
        <button class="btn btn-primary btn-sm" style="flex:1;">关注</button>
        <button class="btn btn-secondary btn-sm" style="flex:1;" onclick="sendMessage('{{ .Topic.Author.Username }}')">私信</button>
      </div>
      {{ end }}
    </div>

    <div class="glass-card side-block fade-in fade-in-delay-1">
      <h3>相关推荐</h3>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {{ range .RelatedTopics }}
        <a href="/t/{{ .ID }}" style="color:var(--color-gray-700);font-size:13px;line-height:1.5;display:block;padding:8px;border-radius:var(--radius-sm);transition:background .2s;" onmouseover="this.style.background='rgba(99,102,241,0.05)'" onmouseout="this.style.background='transparent'">
          {{ .Title }}
        </a>
        {{ else }}
        <p style="font-size:13px;color:var(--color-gray-500);">暂无相关推荐</p>
        {{ end }}
      </div>
    </div>
  </div>
</div>
{{ end }}
