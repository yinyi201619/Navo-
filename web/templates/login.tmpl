{{ define "content" }}
<div class="auth-wrapper fade-in">
  <div class="glass-card auth-card">
    <div style="text-align:center;margin-bottom:24px;">
      <div style="width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,var(--color-primary),var(--color-primary-2));display:flex;align-items:center;justify-content:center;margin:0 auto 12px;color:white;font-size:24px;font-weight:bold;">N</div>
    </div>
    <h1>欢迎回来</h1>
    <p class="sub">登录 {{ .SiteName }}，继续你的探索之旅</p>

    {{ if .Error }}
    <div style="padding:12px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);border-radius:var(--radius-md);color:var(--color-danger);font-size:13px;margin-bottom:16px;">
      {{ .Error }}
    </div>
    {{ end }}

    <form method="post" action="/login">
      <div class="form-group">
        <label class="form-label">用户名</label>
        <input type="text" name="username" class="form-input" placeholder="请输入用户名" required>
      </div>
      <div class="form-group">
        <label class="form-label">密码</label>
        <input type="password" name="password" class="form-input" placeholder="请输入密码" required>
      </div>
      <div class="form-group" style="display:flex;align-items:center;justify-content:space-between;font-size:13px;">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;color:var(--color-gray-600);">
          <input type="checkbox" name="remember" style="accent-color:var(--color-primary);">
          记住我
        </label>
        <a href="/forgot-password" style="color:var(--color-primary);">忘记密码？</a>
      </div>
      <button type="submit" class="btn btn-primary btn-full" style="margin-top:8px;">登 录</button>
    </form>

    <div class="divider">第三方登录</div>

    <a href="/oauth/qq" class="qq-login-btn" style="text-decoration:none;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12.003 2c-2.265 0-6.29 1.364-6.29 7.325v1.195S3.55 14.96 3.55 17.474c0 .665.17 1.025.28 1.025.114 0 .573-.432.573-.432s0 .73.968 1.358c0 0-1.133.478-1.133 1.172 0 .693 3.38 1.074 7.765 1.074 4.385 0 7.765-.381 7.765-1.074 0-.694-1.133-1.172-1.133-1.172.968-.628.968-1.358.968-1.358s.459.432.573.432c.11 0 .28-.36.28-1.025 0-2.514-2.163-6.954-2.163-6.954V9.325C18.293 3.364 14.268 2 12.003 2z"/>
      </svg>
      QQ 快捷登录
    </a>

    <div class="auth-footer">
      还没有账号？<a href="/register">立即注册</a>
    </div>
  </div>
</div>
{{ end }}
