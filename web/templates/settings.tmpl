{{ define "content" }}
<div style="margin:24px 0;">
  <div class="section-title fade-in">
    <h1 style="font-size:20px;">个人设置</h1>
  </div>

  <div class="layout-grid fade-in fade-in-delay-1">
    <div class="layout-main">
      <div class="glass-card" style="padding:24px;">
        <div class="settings-tabs">
          <a href="/settings" class="active">基本资料</a>
          <a href="/settings/security">安全设置</a>
          <a href="/settings/notification">通知设置</a>
        </div>

        {{ if .Success }}
        <div style="padding:12px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius-md);color:var(--color-success);font-size:13px;margin-bottom:16px;">
          {{ .Success }}
        </div>
        {{ end }}

        {{ if .Error }}
        <div style="padding:12px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);border-radius:var(--radius-md);color:var(--color-danger);font-size:13px;margin-bottom:16px;">
          {{ .Error }}
        </div>
        {{ end }}

        <form method="post" action="/settings" enctype="multipart/form-data">
          <div class="form-group" style="text-align:center;">
            <div style="position:relative;display:inline-block;">
              <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ .Username }}" alt="" style="width:80px;height:80px;border-radius:50%;border:3px solid white;box-shadow:0 4px 16px rgba(0,0,0,0.1);">
              <label style="position:absolute;bottom:0;right:0;width:28px;height:28px;border-radius:50%;background:var(--color-primary);color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid white;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <input type="file" name="avatar" accept="image/*" style="display:none;" onchange="this.form.submit()">
              </label>
            </div>
            <p style="font-size:12px;color:var(--color-gray-500);margin-top:8px;">点击头像更换</p>
          </div>

          <div class="form-group">
            <label class="form-label">用户名</label>
            <input type="text" class="form-input" value="{{ .Username }}" disabled style="background:rgba(0,0,0,0.03);color:var(--color-gray-500);">
            <p style="font-size:12px;color:var(--color-gray-400);margin-top:4px;">用户名不可修改</p>
          </div>

          <div class="form-group">
            <label class="form-label">用户名</label>
            <input type="text" class="form-input" value="{{ .User.Username }}" disabled>
          </div>

          <div class="form-group">
            <label class="form-label">邮箱</label>
            <input type="email" name="email" class="form-input" placeholder="请输入邮箱" value="{{ .User.Email }}">
          </div>

          <div class="form-group">
            <label class="form-label">个人签名</label>
            <textarea name="signature" class="form-textarea" rows="2" placeholder="一句话介绍自己" maxlength="50">{{ .User.Signature }}</textarea>
            <p style="font-size:12px;color:var(--color-gray-400);margin-top:4px;text-align:right;">{{ len .User.Signature }}/50</p>
          </div>

          <div class="form-group">
            <label class="form-label">QQ 绑定</label>
            <div style="display:flex;align-items:center;gap:12px;padding:12px;background:rgba(255,255,255,0.5);border-radius:var(--radius-md);">
              <div style="width:40px;height:40px;border-radius:50%;background:#12b7f5;display:flex;align-items:center;justify-content:center;color:white;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.003 2c-2.265 0-6.29 1.364-6.29 7.325v1.195S3.55 14.96 3.55 17.474c0 .665.17 1.025.28 1.025.114 0 .573-.432.573-.432s0 .73.968 1.358c0 0-1.133.478-1.133 1.172 0 .693 3.38 1.074 7.765 1.074 4.385 0 7.765-.381 7.765-1.074 0-.694-1.133-1.172-1.133-1.172.968-.628.968-1.358.968-1.358s.459.432.573.432c.11 0 .28-.36.28-1.025 0-2.514-2.163-6.954-2.163-6.954V9.325C18.293 3.364 14.268 2 12.003 2z"/></svg>
              </div>
              <div style="flex:1;">
                <div style="font-weight:500;color:var(--color-gray-700);">
                  {{ if .Binding }}
                  已绑定 QQ 账号
                  {{ else }}
                  未绑定 QQ
                  {{ end }}
                </div>
                <div style="font-size:12px;color:var(--color-gray-500);">
                  {{ if .Binding }}
                  已绑定 QQ 账号
                  {{ else }}
                  绑定后可使用 QQ 快捷登录
                  {{ end }}
                </div>
              </div>
              {{ if .Binding }}
              <button type="button" class="btn btn-secondary btn-sm" onclick="unbindQQ()">解绑</button>
              {{ else }}
              <a href="/auth/qq" class="btn btn-primary btn-sm">绑定 QQ</a>
              {{ end }}
            </div>
          </div>

          <div style="margin-top:24px;text-align:right;">
            <button type="submit" class="btn btn-primary">保存修改</button>
          </div>
        </form>
      </div>
    </div>

    <div class="layout-side">
      <div class="glass-card side-block">
        <h3>账号信息</h3>
        <div style="font-size:13px;color:var(--color-gray-600);line-height:2;">
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--color-gray-500);">UID</span>
            <span>{{ .User.ID }}</span>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--color-gray-500);">等级</span>
            <span style="color:var(--color-primary);font-weight:600;">Lv.{{ .User.Level }}</span>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--color-gray-500);">积分</span>
            <span style="color:var(--color-primary);font-weight:600;">{{ .User.Points }}</span>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--color-gray-500);">注册时间</span>
            <span>{{ formatTime .User.CreatedAt }}</span>
          </div>
        </div>
      </div>

      <div class="glass-card side-block fade-in-delay-1">
        <h3>快捷操作</h3>
        <div style="display:flex;flex-direction:column;gap:8px;">
          <a href="/u/{{ .Username }}" style="display:flex;align-items:center;gap:10px;padding:10px;border-radius:var(--radius-md);transition:background .2s;" onmouseover="this.style.background='rgba(99,102,241,0.05)'" onmouseout="this.style.background='transparent'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary);"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span style="font-size:13px;color:var(--color-gray-700);">我的主页</span>
          </a>
          <a href="/settings/security" style="display:flex;align-items:center;gap:10px;padding:10px;border-radius:var(--radius-md);transition:background .2s;" onmouseover="this.style.background='rgba(99,102,241,0.05)'" onmouseout="this.style.background='transparent'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary);"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0"/></svg>
            <span style="font-size:13px;color:var(--color-gray-700);">安全设置</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
{{ end }}
