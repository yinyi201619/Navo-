{{ define "content" }}
<div style="margin:24px 0;">
  <div class="glass-card fade-in" style="padding:24px;margin-bottom:24px;">
    <form method="get" action="/search" style="display:flex;gap:12px;">
      <div style="position:relative;flex:1;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--color-gray-400);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" class="form-input" placeholder="搜索帖子、用户、板块..." value="{{ .Keyword }}" style="padding-left:44px;font-size:15px;" autofocus>
      </div>
      <button type="submit" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        搜索
      </button>
    </form>
  </div>

  {{ if .Keyword }}
  <div class="section-title fade-in fade-in-delay-1">
    <h2 style="font-size:18px;">
      搜索结果：<span style="color:var(--color-primary);">"{{ .Keyword }}"</span>
      <span style="font-size:13px;color:var(--color-gray-500);font-weight:normal;">共 {{ .Total }} 条结果</span>
    </h2>
    <div class="tabs">
      <a href="?q={{ .Keyword }}&type=topic" class="tab {{ if eq .Type "topic" }}active{{ end }}">帖子</a>
      <a href="?q={{ .Keyword }}&type=user" class="tab {{ if eq .Type "user" }}active{{ end }}">用户</a>
      <a href="?q={{ .Keyword }}&type=category" class="tab {{ if eq .Type "category" }}active{{ end }}">板块</a>
    </div>
  </div>

  <div class="layout-grid fade-in fade-in-delay-2">
    <div class="layout-main">
      {{ if eq .Type "topic" }}
      <div class="topic-list">
        {{ range $i, $t := .Results }}
        <div class="topic-item">
          <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ $t.Author.Username }}" alt="" class="topic-avatar">
          <div class="topic-main">
            <div class="topic-title">
              {{ if $t.IsEssence }}<span class="tag tag-essence">精华</span>{{ end }}
              <a href="/t/{{ $t.ID }}">{{ highlight $t.Title $.Keyword }}</a>
            </div>
            <div style="font-size:13px;color:var(--color-gray-500);margin:6px 0;line-height:1.6;">
              {{ $preview := "" }}
              {{ if gt (len $t.Content) 120 }}{{ $preview = slice $t.Content 0 120 }}{{ else }}{{ $preview = $t.Content }}{{ end }}
              {{ highlight $preview $.Keyword }}
            </div>
            <div class="topic-meta">
              <span class="author">{{ $t.Author.Username }}</span>
              <span>{{ $t.Category.Name }}</span>
              <span>{{ relativeTime $t.CreatedAt }}</span>
            </div>
          </div>
          <div class="topic-stats">
            <span title="回复">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {{ $t.ReplyCount }}
            </span>
          </div>
        </div>
        {{ else }}
        <div class="glass-card" style="padding:60px;text-align:center;color:var(--color-gray-500);">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 12px;opacity:0.3;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <p>没有找到相关帖子</p>
          <p style="font-size:13px;margin-top:4px;">试试其他关键词？</p>
        </div>
        {{ end }}
      </div>
      {{ else if eq .Type "user" }}
      <div class="glass-card" style="padding:0;overflow:hidden;">
        {{ range $u := .Results }}
        <div style="display:flex;align-items:center;gap:14px;padding:16px 20px;border-bottom:1px solid rgba(0,0,0,0.04);">
          <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ $u.Username }}" alt="" style="width:48px;height:48px;border-radius:50%;border:2px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
          <div style="flex:1;">
            <div style="font-weight:600;color:var(--color-gray-800);display:flex;align-items:center;gap:8px;">
              <a href="/u/{{ $u.Username }}" style="color:inherit;">{{ highlight $u.Username $.Keyword }}</a>
              {{ if $u.IsVerified }}
              <span class="verified-badge">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:14px;height:14px;"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
              {{ end }}
            </div>
            <div style="font-size:13px;color:var(--color-gray-500);margin-top:2px;">
              {{ if $u.Signature }}{{ $u.Signature }}{{ else }}这个人很懒，什么都没写{{ end }}
            </div>
          </div>
          <span class="level-badge">Lv.{{ $u.Level }}</span>
        </div>
        {{ else }}
        <div style="padding:60px;text-align:center;color:var(--color-gray-500);">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 12px;opacity:0.3;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <p>没有找到相关用户</p>
        </div>
        {{ end }}
      </div>
      {{ else if eq .Type "category" }}
      <div class="category-grid" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr));">
        {{ range $c := .Results }}
        <a href="/c/{{ $c.Slug }}" class="glass-card glass-card-hover" style="padding:20px;display:block;text-decoration:none;color:inherit;">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">
            <div style="width:44px;height:44px;border-radius:var(--radius-md);background:linear-gradient(135deg,var(--color-primary),var(--color-primary-2));display:flex;align-items:center;justify-content:center;color:white;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </div>
            <div>
              <h3 style="font-size:15px;color:var(--color-gray-800);">{{ highlight $c.Name $.Keyword }}</h3>
              <span style="font-size:11px;color:var(--color-gray-400);">{{ $c.TopicCount }} 主题</span>
            </div>
          </div>
          <p style="font-size:12px;color:var(--color-gray-500);line-height:1.5;">
            {{ if $c.Description }}{{ $c.Description }}{{ else }}暂无描述{{ end }}
          </p>
        </a>
        {{ else }}
        <div class="glass-card" style="padding:60px;text-align:center;color:var(--color-gray-500);grid-column:1/-1;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 12px;opacity:0.3;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <p>没有找到相关板块</p>
        </div>
        {{ end }}
      </div>
      {{ end }}

      {{ if .TotalPages }}
      <div class="pagination">
        {{ if eq .Page 1 }}
        <span class="disabled">上一页</span>
        {{ else }}
        <a href="?q={{ .Keyword }}&type={{ .Type }}&page={{ sub .Page 1 }}">上一页</a>
        {{ end }}
        {{ range $i := seq 1 .TotalPages }}
          {{ if eq $i $.Page }}
          <span class="current">{{ $i }}</span>
          {{ else }}
          <a href="?q={{ $.Keyword }}&type={{ $.Type }}&page={{ $i }}">{{ $i }}</a>
          {{ end }}
        {{ end }}
        {{ if eq .Page .TotalPages }}
        <span class="disabled">下一页</span>
        {{ else }}
        <a href="?q={{ .Keyword }}&type={{ .Type }}&page={{ add .Page 1 }}">下一页</a>
        {{ end }}
      </div>
      {{ end }}
    </div>

    <div class="layout-side">
      <div class="glass-card side-block">
        <h3>热门搜索</h3>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          {{ range $h := .HotSearches }}
          <a href="?q={{ $h }}" class="tag" style="text-decoration:none;">{{ $h }}</a>
          {{ end }}
        </div>
      </div>

      <div class="glass-card side-block fade-in-delay-1">
        <h3>搜索提示</h3>
        <ul style="font-size:12px;color:var(--color-gray-600);line-height:1.8;padding-left:16px;">
          <li>输入关键词进行搜索</li>
          <li>支持搜索帖子、用户、板块</li>
          <li>关键词越精确结果越准确</li>
        </ul>
      </div>
    </div>
  </div>
  {{ else }}
  <div class="glass-card fade-in fade-in-delay-1" style="padding:80px 40px;text-align:center;">
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 16px;color:var(--color-primary);opacity:0.6;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <h2 style="font-size:18px;color:var(--color-gray-800);margin-bottom:8px;">开始搜索</h2>
    <p style="color:var(--color-gray-500);font-size:14px;">在上方输入关键词搜索你感兴趣的内容</p>
  </div>
  {{ end }}
</div>
{{ end }}
