{{ define "content" }}
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <div class="admin-logo">
        <div class="admin-logo-icon">N</div>
        <span>Navo NT 管理</span>
      </div>
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-item active">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        仪表盘
      </a>
      <a href="/admin/users" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        用户管理
      </a>
      <a href="/admin/topics" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        帖子管理
      </a>
      <a href="/admin/categories" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        板块管理
      </a>
      <a href="/admin/verifications" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        认证管理
      </a>
      <a href="/admin/points" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        积分管理
      </a>
      <a href="/admin/logs" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
        </svg>
        操作日志
      </a>
      <a href="/admin/settings" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
        系统设置
      </a>
    </nav>
    <div class="admin-sidebar-footer">
      <a href="/" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        返回首页
      </a>
    </div>
  </aside>

  <main class="admin-content">
    <div class="admin-page-header">
      <div>
        <h1 class="admin-page-title">仪表盘</h1>
        <p class="admin-page-desc">欢迎回来，查看社区运营数据概览</p>
      </div>
      <div class="admin-page-actions">
        <span class="admin-time">{{ .Now.Format "2006-01-02 15:04:05" }}</span>
      </div>
    </div>

    <div class="stats-grid">
      <div class="admin-card stat-card">
        <div class="stat-icon stat-icon-blue">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">{{ .Stats.User }}</div>
          <div class="stat-label">注册用户</div>
        </div>
        <div class="stat-trend stat-up">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
          +12.5%
        </div>
      </div>

      <div class="admin-card stat-card">
        <div class="stat-icon stat-icon-purple">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">{{ .Stats.Topic }}</div>
          <div class="stat-label">主题帖子</div>
        </div>
        <div class="stat-trend stat-up">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
          +8.3%
        </div>
      </div>

      <div class="admin-card stat-card">
        <div class="stat-icon stat-icon-green">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">{{ .Stats.Reply }}</div>
          <div class="stat-label">回复数量</div>
        </div>
        <div class="stat-trend stat-up">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
          +15.2%
        </div>
      </div>

      <div class="admin-card stat-card">
        <div class="stat-icon stat-icon-orange">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">{{ .Stats.Category }}</div>
          <div class="stat-label">板块数量</div>
        </div>
        <div class="stat-trend stat-stable">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          持平
        </div>
      </div>
    </div>

    <div class="admin-grid-2">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">用户增长趋势</h3>
          <div class="admin-card-actions">
            <select class="admin-select-sm">
              <option>近7天</option>
              <option>近30天</option>
              <option>近90天</option>
            </select>
          </div>
        </div>
        <div class="chart-placeholder">
          <div class="chart-bars">
            <div class="chart-bar" style="height: 45%;"><span>12</span></div>
            <div class="chart-bar" style="height: 60%;"><span>18</span></div>
            <div class="chart-bar" style="height: 40%;"><span>10</span></div>
            <div class="chart-bar" style="height: 75%;"><span>25</span></div>
            <div class="chart-bar" style="height: 55%;"><span>16</span></div>
            <div class="chart-bar" style="height: 85%;"><span>30</span></div>
            <div class="chart-bar" style="height: 70%;"><span>22</span></div>
          </div>
          <div class="chart-labels">
            <span>周一</span><span>周二</span><span>周三</span><span>周四</span><span>周五</span><span>周六</span><span>周日</span>
          </div>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">活跃度分布</h3>
          <div class="admin-card-actions">
            <span class="admin-badge">今日</span>
          </div>
        </div>
        <div class="activity-chart">
          <div class="activity-item">
            <div class="activity-label">发帖</div>
            <div class="activity-bar-wrap">
              <div class="activity-bar activity-bar-blue" style="width: 65%;"></div>
            </div>
            <div class="activity-value">42</div>
          </div>
          <div class="activity-item">
            <div class="activity-label">回复</div>
            <div class="activity-bar-wrap">
              <div class="activity-bar activity-bar-purple" style="width: 85%;"></div>
            </div>
            <div class="activity-value">128</div>
          </div>
          <div class="activity-item">
            <div class="activity-label">签到</div>
            <div class="activity-bar-wrap">
              <div class="activity-bar activity-bar-green" style="width: 50%;"></div>
            </div>
            <div class="activity-value">86</div>
          </div>
          <div class="activity-item">
            <div class="activity-label">新注册</div>
            <div class="activity-bar-wrap">
              <div class="activity-bar activity-bar-orange" style="width: 30%;"></div>
            </div>
            <div class="activity-value">15</div>
          </div>
        </div>
      </div>
    </div>

    <div class="admin-grid-2">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">最新注册用户</h3>
          <a href="/admin/users" class="admin-link">查看全部 →</a>
        </div>
        <div class="admin-list">
          {{ range $i, $u := .RecentUsers }}
          <div class="admin-list-item">
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ $u.Username }}" alt="" class="admin-avatar-sm">
            <div class="admin-list-info">
              <div class="admin-list-title">{{ $u.Username }}</div>
              <div class="admin-list-sub">{{ relativeTime $u.CreatedAt }} 注册</div>
            </div>
            <span class="status-badge status-active">正常</span>
          </div>
          {{ else }}
          <div class="admin-empty">暂无数据</div>
          {{ end }}
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">热门帖子</h3>
          <a href="/admin/topics" class="admin-link">查看全部 →</a>
        </div>
        <div class="admin-list">
          {{ range $i, $t := .HotTopics }}
          <div class="admin-list-item">
            <div class="admin-list-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div class="admin-list-info">
              <div class="admin-list-title">{{ $t.Title }}</div>
              <div class="admin-list-sub">{{ $t.Author.Username }} · {{ $t.ReplyCount }} 回复</div>
            </div>
            <span class="admin-badge-soft">{{ $t.ViewCount }}</span>
          </div>
          {{ else }}
          <div class="admin-empty">暂无数据</div>
          {{ end }}
        </div>
      </div>
    </div>
  </main>
</div>
{{ end }}
