{{ define "content" }}
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <div class="admin-logo">
        <div class="admin-logo-icon">N</div>
        <span>Navo NT 管理</span>
      </div>
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        仪表盘
      </a>
      <a href="/admin/users" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        用户管理
      </a>
      <a href="/admin/topics" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        帖子管理
      </a>
      <a href="/admin/categories" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        板块管理
      </a>
      <a href="/admin/verifications" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        认证管理
      </a>
      <a href="/admin/points" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        积分管理
      </a>
      <a href="/admin/logs" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
        </svg>
        操作日志
      </a>
      <a href="/admin/settings" class="admin-nav-item active">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
        系统设置
      </a>
    </nav>
    <div class="admin-sidebar-footer">
      <a href="/" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        返回首页
      </a>
    </div>
  </aside>

  <main class="admin-content">
    <div class="admin-page-header">
      <div>
        <h1 class="admin-page-title">系统设置</h1>
        <p class="admin-page-desc">配置站点基础参数和功能开关</p>
      </div>
    </div>

    <form method="post" action="/admin/settings">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            </svg>
            站点信息
          </h3>
        </div>
        <div class="admin-form-grid">
          <div class="admin-form-group">
            <label class="admin-form-label">站点名称</label>
            <input type="text" name="site_name" class="admin-input" value="{{ .Settings.SiteName }}">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">站点描述</label>
            <input type="text" name="site_desc" class="admin-input" value="{{ .Settings.SiteDesc }}">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">站点关键词</label>
            <input type="text" name="site_keywords" class="admin-input" value="{{ .Settings.SiteKeywords }}" placeholder="多个关键词用逗号分隔">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">站点域名</label>
            <input type="url" name="site_url" class="admin-input" value="{{ .Settings.SiteUrl }}">
          </div>
          <div class="admin-form-group admin-form-full">
            <label class="admin-form-label">站点公告</label>
            <textarea name="site_notice" class="admin-textarea" rows="3" placeholder="显示在首页的公告内容">{{ .Settings.SiteNotice }}</textarea>
          </div>
          <div class="admin-form-group admin-form-full">
            <label class="admin-form-label">页脚代码</label>
            <textarea name="footer_code" class="admin-textarea" rows="3" placeholder="可放置统计代码等">{{ .Settings.FooterCode }}</textarea>
          </div>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
            </svg>
            注册与登录
          </h3>
        </div>
        <div class="admin-form-grid">
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="register_enabled" {{ if .Settings.RegisterEnabled }}checked{{ end }}>
              <span>开启用户注册</span>
            </label>
            <p class="admin-form-hint">关闭后新用户将无法注册账号</p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="email_verify" {{ if .Settings.EmailVerify }}checked{{ end }}>
              <span>注册需要邮箱验证</span>
            </label>
            <p class="admin-form-hint">开启后注册需验证邮箱</p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="invite_only" {{ if .Settings.InviteOnly }}checked{{ end }}>
              <span>邀请码注册模式</span>
            </label>
            <p class="admin-form-hint">仅允许使用邀请码注册</p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">默认用户组</label>
            <select name="default_role" class="admin-select">
              <option value="user" {{ if eq .Settings.DefaultRole "user" }}selected{{ end }}>普通用户</option>
            </select>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">新用户初始积分</label>
            <input type="number" name="new_user_points" class="admin-input" value="{{ .Settings.NewUserPoints }}" min="0">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">每日登录奖励</label>
            <input type="number" name="daily_login_points" class="admin-input" value="{{ .Settings.DailyLoginPoints }}" min="0">
          </div>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            上传设置
          </h3>
        </div>
        <div class="admin-form-grid">
          <div class="admin-form-group">
            <label class="admin-form-label">单张图片最大 (MB)</label>
            <input type="number" name="image_max_size" class="admin-input" value="{{ .Settings.ImageMaxSize }}" min="1">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">单个附件最大 (MB)</label>
            <input type="number" name="file_max_size" class="admin-input" value="{{ .Settings.FileMaxSize }}" min="1">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">允许的图片格式</label>
            <input type="text" name="image_extensions" class="admin-input" value="{{ .Settings.ImageExtensions }}" placeholder="jpg,png,gif,webp">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">允许的附件格式</label>
            <input type="text" name="file_extensions" class="admin-input" value="{{ .Settings.FileExtensions }}" placeholder="zip,rar,pdf">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">每日上传上限 (张/人)</label>
            <input type="number" name="daily_upload_limit" class="admin-input" value="{{ .Settings.DailyUploadLimit }}" min="0" placeholder="0为不限">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="watermark_enabled" {{ if .Settings.WatermarkEnabled }}checked{{ end }}>
              <span>开启图片水印</span>
            </label>
            <p class="admin-form-hint">上传图片自动添加水印</p>
          </div>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            内容设置
          </h3>
        </div>
        <div class="admin-form-grid">
          <div class="admin-form-group">
            <label class="admin-form-label">帖子每页显示数</label>
            <input type="number" name="topics_per_page" class="admin-input" value="{{ .Settings.TopicsPerPage }}" min="10" max="100">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">回复每页显示数</label>
            <input type="number" name="replies_per_page" class="admin-input" value="{{ .Settings.RepliesPerPage }}" min="10" max="100">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="post_review" {{ if .Settings.PostReview }}checked{{ end }}>
              <span>发帖需要审核</span>
            </label>
            <p class="admin-form-hint">新发帖需管理员审核后显示</p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="comment_review" {{ if .Settings.CommentReview }}checked{{ end }}>
              <span>回复需要审核</span>
            </label>
            <p class="admin-form-hint">新回复需管理员审核后显示</p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="edit_time_limit" {{ if .Settings.EditTimeLimit }}checked{{ end }}>
              <span>编辑时间限制</span>
            </label>
            <p class="admin-form-hint">发帖后一定时间内允许编辑</p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">可编辑时长 (分钟)</label>
            <input type="number" name="edit_time_minutes" class="admin-input" value="{{ .Settings.EditTimeMinutes }}" min="0">
          </div>
        </div>
      </div>

      <div class="admin-form-actions admin-form-actions-bottom">
        <button type="submit" class="btn btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          保存设置
        </button>
        <button type="reset" class="btn btn-secondary btn-lg" style="margin-left:12px;">重置</button>
      </div>
    </form>
  </main>
</div>
{{ end }}
