{{ define "content" }}
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <div class="admin-logo">
        <div class="admin-logo-icon">N</div>
        <span>Navo NT 管理</span>
      </div>
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        仪表盘
      </a>
      <a href="/admin/users" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        用户管理
      </a>
      <a href="/admin/topics" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        帖子管理
      </a>
      <a href="/admin/categories" class="admin-nav-item active">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        板块管理
      </a>
      <a href="/admin/verifications" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        认证管理
      </a>
      <a href="/admin/points" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        积分管理
      </a>
      <a href="/admin/logs" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
        </svg>
        操作日志
      </a>
      <a href="/admin/settings" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
        系统设置
      </a>
    </nav>
    <div class="admin-sidebar-footer">
      <a href="/" class="admin-nav-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        返回首页
      </a>
    </div>
  </aside>

  <main class="admin-content">
    <div class="admin-page-header">
      <div>
        <h1 class="admin-page-title">板块管理</h1>
        <p class="admin-page-desc">管理社区板块分类</p>
      </div>
      <div class="admin-page-actions">
        <button class="btn btn-primary" onclick="showAddCategory()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          添加板块
        </button>
      </div>
    </div>

    <div class="admin-grid-2">
      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">板块列表</h3>
          <div class="admin-card-actions">
            <span class="admin-badge-soft">共 {{ len .Categories }} 个板块</span>
          </div>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>排序</th>
                <th>名称</th>
                <th>别名</th>
                <th>主题数</th>
                <th>状态</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              {{ range $c := .Categories }}
              <tr>
                <td><span class="admin-sort-num">{{ $c.SortOrder }}</span></td>
                <td>
                  <div class="admin-category-cell">
                    <div class="admin-category-icon" style="background:rgba(99,102,241,0.2);color:rgb(99,102,241);">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                      </svg>
                    </div>
                    <span>{{ $c.Name }}</span>
                  </div>
                </td>
                <td><code class="admin-code">{{ $c.Slug }}</code></td>
                <td>{{ $c.TopicCount }}</td>
                <td>
                  <span class="status-badge status-active">正常</span>
                </td>
                <td>
                  <div class="admin-actions">
                    <button class="admin-action-btn admin-action-edit" onclick="editCategory('{{ $c.ID }}')">编辑</button>
                    <button class="admin-action-btn admin-action-ban" onclick="deleteCategory('{{ $c.ID }}')">删除</button>
                  </div>
                </td>
              </tr>
              {{ else }}
              <tr>
                <td colspan="6" class="admin-empty">暂无板块数据</td>
              </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3 class="admin-card-title">{{ if .EditingCategory }}编辑板块{{ else }}添加板块{{ end }}</h3>
        </div>
        <form method="post" action="/admin/categories{{ if .EditingCategory }}/{{ .EditingCategory.ID }}/edit{{ end }}" class="admin-form">
          <div class="admin-form-group">
            <label class="admin-form-label">板块名称</label>
            <input type="text" name="name" class="admin-input" placeholder="请输入板块名称" value="{{ if .EditingCategory }}{{ .EditingCategory.Name }}{{ end }}">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">板块别名 (Slug)</label>
            <input type="text" name="slug" class="admin-input" placeholder="英文别名，用于URL" value="{{ if .EditingCategory }}{{ .EditingCategory.Slug }}{{ end }}">
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">板块描述</label>
            <textarea name="description" class="admin-textarea" rows="3" placeholder="简要描述该板块">{{ if .EditingCategory }}{{ .EditingCategory.Description }}{{ end }}</textarea>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label class="admin-form-label">图标</label>
              <input type="text" name="icon" class="admin-input" placeholder="图标" value="{{ if .EditingCategory }}{{ .EditingCategory.Icon }}{{ end }}">
            </div>
            <div class="admin-form-group">
              <label class="admin-form-label">排序</label>
              <input type="number" name="sort_order" class="admin-input" value="{{ if .EditingCategory }}{{ .EditingCategory.SortOrder }}{{ else }}0{{ end }}">
            </div>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-checkbox">
              <input type="checkbox" name="is_active" {{ if or (not .EditingCategory) .EditingCategory.IsActive }}checked{{ end }}>
              <span>启用该板块</span>
            </label>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="btn btn-primary">{{ if .EditingCategory }}保存修改{{ else }}添加板块{{ end }}</button>
            {{ if .EditingCategory }}
            <a href="/admin/categories" class="btn btn-secondary" style="margin-left:8px;">取消</a>
            {{ end }}
          </div>
        </form>
      </div>
    </div>
  </main>
</div>
{{ end }}
