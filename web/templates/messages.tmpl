{{ define "content" }}
<div style="margin:24px 0;">
  <div class="section-title fade-in">
    <h1 style="font-size:20px;">私信</h1>
    <span style="font-size:13px;color:var(--color-gray-500);">{{ .UnreadCount }} 条未读</span>
  </div>

  <div class="glass-card fade-in fade-in-delay-1" style="overflow:hidden;">
    <div class="message-layout" style="min-height:500px;">
      <div class="message-sidebar">
        <div style="padding:12px 16px;border-bottom:1px solid rgba(0,0,0,0.06);">
          <input type="text" class="form-input" placeholder="搜索联系人..." style="font-size:13px;padding:8px 12px;">
        </div>

        {{ range $i, $c := .Conversations }}
        <div class="conv-item {{ if $c.IsUnread }}active{{ end }}" onclick="openConversation('{{ $c.ID }}')">
          <img src="https://api.dicebear.com/7.x/avataaars/svg?seed={{ $c.User.Username }}" alt="" class="conv-avatar">
          <div class="conv-info">
            <div class="conv-name">
              <span>{{ $c.User.Username }}</span>
              <span class="conv-time">{{ $c.LastTime }}</span>
            </div>
            <div class="conv-preview">
              {{ if $c.IsMe }}我：{{ end }}{{ $c.LastMessage }}
            </div>
          </div>
          {{ if $c.UnreadCount }}
          <span class="conv-unread">{{ $c.UnreadCount }}</span>
          {{ end }}
        </div>
        {{ else }}
        <div style="padding:40px 20px;text-align:center;color:var(--color-gray-400);font-size:13px;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 10px;opacity:0.5;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          暂无私信
        </div>
        {{ end }}
      </div>

      <div class="message-main" style="display:flex;align-items:center;justify-content:center;background:rgba(243,244,246,0.3);">
        <div style="text-align:center;color:var(--color-gray-400);">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 12px;opacity:0.4;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <p style="font-size:14px;">选择一个会话开始聊天</p>
        </div>
      </div>
    </div>
  </div>
</div>
{{ end }}
