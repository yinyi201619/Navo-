{{ define "content" }}
<div style="margin:24px 0;">
  <div class="section-title fade-in">
    <h1 style="font-size:20px;">安全设置</h1>
  </div>

  <div class="layout-grid fade-in fade-in-delay-1">
    <div class="layout-main">
      <div class="glass-card" style="padding:24px;">
        <div class="settings-tabs">
          <a href="/settings">基本资料</a>
          <a href="/settings/security" class="active">安全设置</a>
          <a href="/settings/notification">通知设置</a>
        </div>

        {{ if .Success }}
        <div style="padding:12px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius-md);color:var(--color-success);font-size:13px;margin-bottom:16px;">
          {{ .Success }}
        </div>
        {{ end }}

        {{ if .Error }}
        <div style="padding:12px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);border-radius:var(--radius-md);color:var(--color-danger);font-size:13px;margin-bottom:16px;">
          {{ .Error }}
        </div>
        {{ end }}

        <h3 style="font-size:16px;color:var(--color-gray-800);margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid rgba(0,0,0,0.06);">修改密码</h3>

        <form method="post" action="/settings/security">
          <div class="form-group">
            <label class="form-label">当前密码</label>
            <input type="password" name="old_password" class="form-input" placeholder="请输入当前密码" required>
          </div>

          <div class="form-group">
            <label class="form-label">新密码</label>
            <input type="password" name="new_password" class="form-input" placeholder="请输入新密码，至少6位" required minlength="6">
          </div>

          <div class="form-group">
            <label class="form-label">确认新密码</label>
            <input type="password" name="confirm_password" class="form-input" placeholder="请再次输入新密码" required minlength="6">
          </div>

          <div style="padding:16px;background:rgba(245,158,11,0.08);border-radius:var(--radius-md);margin-bottom:20px;">
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-warning);flex-shrink:0;margin-top:1px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <div style="font-size:13px;color:var(--color-gray-600);line-height:1.6;">
                <strong style="color:var(--color-warning);">密码安全建议</strong><br>
                建议密码长度至少8位，包含大小写字母、数字和特殊字符，定期更换密码可以提高账号安全性。
              </div>
            </div>
          </div>

          <div style="text-align:right;">
            <button type="submit" class="btn btn-primary">确认修改</button>
          </div>
        </form>
      </div>

      <div class="glass-card" style="padding:24px;margin-top:20px;">
        <h3 style="font-size:16px;color:var(--color-gray-800);margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid rgba(0,0,0,0.06);">登录设备</h3>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {{ range $d := .Devices }}
          <div style="display:flex;align-items:center;gap:12px;padding:12px;background:rgba(255,255,255,0.5);border-radius:var(--radius-md);">
            <div style="width:40px;height:40px;border-radius:var(--radius-md);background:linear-gradient(135deg,var(--color-primary),var(--color-primary-2));display:flex;align-items:center;justify-content:center;color:white;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div style="flex:1;">
              <div style="font-weight:500;color:var(--color-gray-700);font-size:14px;">{{ $d.Device }}</div>
              <div style="font-size:12px;color:var(--color-gray-500);">{{ $d.Location }} · {{ $d.LastTime }}</div>
            </div>
            {{ if $d.IsCurrent }}
            <span class="tag" style="background:rgba(16,185,129,0.1);color:var(--color-success);">当前设备</span>
            {{ else }}
            <button class="btn btn-secondary btn-sm" onclick="logoutDevice({{ $d.ID }})">下线</button>
            {{ end }}
          </div>
          {{ else }}
          <p style="text-align:center;color:var(--color-gray-500);font-size:13px;padding:20px 0;">暂无登录设备记录</p>
          {{ end }}
        </div>
      </div>
    </div>

    <div class="layout-side">
      <div class="glass-card side-block">
        <h3>安全等级</h3>
        <div style="text-align:center;padding:10px 0;">
          <div style="width:80px;height:80px;border-radius:50%;border:4px solid var(--color-success);display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
            <span style="font-size:24px;font-weight:700;color:var(--color-success);">{{ .SecurityScore }}</span>
          </div>
          <p style="font-size:14px;color:var(--color-gray-700);font-weight:500;">安全</p>
          <p style="font-size:12px;color:var(--color-gray-500);margin-top:4px;">您的账号安全性良好</p>
        </div>
      </div>

      <div class="glass-card side-block fade-in-delay-1">
        <h3>安全选项</h3>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(0,0,0,0.04);">
            <span style="font-size:13px;color:var(--color-gray-700);">密码强度</span>
            <span style="font-size:12px;color:var(--color-success);">强</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(0,0,0,0.04);">
            <span style="font-size:13px;color:var(--color-gray-700);">邮箱验证</span>
            <span style="font-size:12px;color:var(--color-success);">已验证</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;">
            <span style="font-size:13px;color:var(--color-gray-700);">QQ绑定</span>
            <span style="font-size:12px;color:{{ if .User.QQOpenID }}var(--color-success){{ else }}var(--color-warning){{ end }};">{{ if .User.QQOpenID }}已绑定{{ else }}未绑定{{ end }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{ end }}
